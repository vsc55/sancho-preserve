<project xmlns="http://maven.apache.org/POM/4.0.0">
  <modelVersion>4.0.0</modelVersion>
  <groupId>org.sancho.thirdparty</groupId>
  <artifactId>org.eclipse.jface</artifactId>
  <version>3.31.0-unsigned</version>
  <description>Eclipse JFace 3.31.0 with jar signatures stripped, so the vendored
  org.eclipse.jface.viewers.TableTreeViewer can share the package.</description>
  <dependencies>
    <dependency>
      <groupId>org.sancho.thirdparty</groupId>
      <artifactId>org.eclipse.swt.win32.win32.x86_64</artifactId>
      <version>3.124.0-unsigned</version>
    </dependency>
    <dependency>
      <groupId>org.eclipse.platform</groupId>
      <artifactId>org.eclipse.core.commands</artifactId>
      <version>3.11.100</version>
    </dependency>
    <dependency>
      <groupId>org.eclipse.platform</groupId>
      <artifactId>org.eclipse.equinox.common</artifactId>
      <version>3.18.100</version>
    </dependency>
  </dependencies>
</project>
